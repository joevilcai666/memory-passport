# Keep repository text deterministic across Linux, macOS, and Windows clones.
* text=auto eol=lf

# Linux-executed entrypoints must survive Windows autocrlf checkouts.
*.sh text eol=lf
.env.example text eol=lf
Dockerfile text eol=lf
**/Dockerfile text eol=lf

# Windows-native scripts retain their platform convention.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
