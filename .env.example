# ============================================================================
# Memory Passport local environment template.
# Copy to `.env` (gitignored). The default demo works without changing any
# model credentials. Real HMS mode requires replacing the three API-key
# placeholders below.
# ============================================================================

# ---- Postgres (shared by MP + HMS) -----------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev_password_change_me
POSTGRES_DB=postgres

# These are created by docker/postgres-init.sh on first boot. Override only if
# you want different credentials (and update MP/HMS DATABASE_URL accordingly).
MP_DB_USER=mp
MP_DB_PASSWORD=mp_dev_password_change_me
MP_DB_NAME=memory_passport
HMS_DB_USER=hms
HMS_DB_PASSWORD=hms_dev_password_change_me
HMS_DB_NAME=hms

# ---- Memory Passport backend ------------------------------------------------
MP_PORT=8000
MP_MEMORY_ENGINE_MODE=demo
# Seeded sandbox API key — must equal the one in src/lib/mock-data.ts so the
# "valid sandbox key authenticates" acceptance test holds.
MP_SEED_API_KEY=mp_sandbox_LK39sn8vQ4x2pR7wY1tBz0Hd
MP_EXPORT_TOKEN_TTL_SECONDS=900
MP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Next.js server → Memory Passport wiring -------------------------------
# Read only by the Next.js server-side product gateway. Never prefix tenant
# credentials with NEXT_PUBLIC_: that would inline them into browser assets.
MP_API_URL=http://127.0.0.1:8000
MP_API_KEY=mp_sandbox_LK39sn8vQ4x2pR7wY1tBz0Hd
# Until operator authentication lands, production requires an explicit opt-in
# that is suitable only for localhost or a trusted evaluation network.
MP_GATEWAY_ALLOW_UNAUTHENTICATED=false

# ---- HMS-compatible service -------------------------------------------------
# HMS tenant key. MP stores a per-tenant HMS key on the tenants table and sends
# the resolved tenant's key as `Authorization: Bearer <key>` when calling
# hms-api (see backend/app/hms/__init__.py:hms_client_for_tenant). This variable
# is the Luna tenant's key (used by the seed + the health probe + as a fallback
# when no tenant context is available). New tenants get a minted key on first
# create_app. See backend/app/hms/tenant.py for the full multi-tenant design.
HMS_API_TENANT_API_KEY=hms_tenant_luna_change_me

# HMS tenant schema. All HMS banks for the Luna tenant live under this Postgres
# schema (HMS applies schema-name to every table via its TenantExtension).
HMS_API_DATABASE_SCHEMA=tenant_luna

# Real-HMS mode only: the custom MPTenantExtension maps each tenant's HMS key
# to its own schema. Format: <key1>=<schema1>,<key2>=<schema2>. Default seeds
# the Luna pair; add a new pair per onboarded tenant. Ignored by the demo HMS.
# HMS_API_TENANT_KEYS=hms_tenant_luna_change_me=tenant_luna,hms_acme_key=tenant_acme

# Used only by the real-HMS overlay. Keep true only when deliberately bypassing
# the pinned HMS startup probe; `make real-up` still requires non-placeholder
# credentials because retain/recall will make provider calls.
HMS_API_SKIP_LLM_VERIFICATION=false

# ---- LLM + embeddings (HMS requires these to start) ------------------------
# These settings are ignored by the default deterministic service. Replace all
# three key placeholders before `make real-up`.
HMS_API_LLM_PROVIDER=openai
HMS_API_LLM_MODEL=gpt-4o
HMS_API_LLM_API_KEY=openai_key_change_me
HMS_API_LLM_BASE_URL=

HMS_API_RETAIN_LLM_PROVIDER=openai
HMS_API_RETAIN_LLM_MODEL=gpt-4o
HMS_API_RETAIN_LLM_API_KEY=openai_key_change_me
HMS_API_RETAIN_LLM_BASE_URL=

HMS_API_EMBEDDINGS_PROVIDER=openai
HMS_API_EMBEDDINGS_OPENAI_MODEL=text-embedding-3-small
HMS_API_EMBEDDINGS_OPENAI_API_KEY=openai_key_change_me
HMS_API_EMBEDDINGS_OPENAI_BASE_URL=
