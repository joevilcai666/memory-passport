# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.runtime/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# backend (python) — Slice 1
/backend/.venv/
/backend/__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# docker volumes (gitignored; recreated by docker-compose up)
/volumes/
/var/exports/

# operator backups (scripts/backup.sh writes here by default)
/backups/

# local validation outputs containing generated credentials/tokens
/artifacts/remediation-2026-07-22/api-results.json
/artifacts/validation-2026-07-22/live_api_results.json

# local agent/IDE session workspace (not part of the repo)
.zcode/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
